// Tests: nested function calls — passing the return value of a call as an argument

fn double(x: i64) -> i64 {
    return x * 2;
}

fn inc(x: i64) -> i64 {
    return x + 1;
}

fn square(x: i64) -> i64 {
    return x * x;
}

fn add(a: i64, b: i64) -> i64 {
    return a + b;
}

fn negate(x: i64) -> i64 {
    return -x;
}

fn main() {
    // Two levels of nesting
    let r1: i64 = double(inc(5));
    println(r1);

    let r2: i64 = square(double(3));
    println(r2);

    // Three levels
    let r3: i64 = inc(double(inc(4)));
    println(r3);

    // Calls in binary expressions
    let r4: i64 = double(3) + square(2);
    println(r4);

    // Calls as both arguments
    let r5: i64 = add(double(4), square(3));
    println(r5);

    // Negation of a call
    let r6: i64 = negate(double(7));
    println(r6);

    // Call result used in condition
    if double(5) > square(3) {
        println("double wins");
    } else {
        println("square wins");
    }

    // Call result in while condition
    var x: i64 = 1;
    while double(x) < 100 {
        x = inc(x);
    }
    println(x);
}
