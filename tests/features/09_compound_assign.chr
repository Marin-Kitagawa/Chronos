// Tests: compound assignment operators +=, -=, *=, /=, %=

fn main() {
    // Addition assignment
    var a: i64 = 10;
    a += 5;
    println(a);

    // Subtraction assignment
    var b: i64 = 20;
    b -= 7;
    println(b);

    // Multiplication assignment
    var c: i64 = 4;
    c *= 3;
    println(c);

    // Division assignment
    var d: i64 = 30;
    d /= 6;
    println(d);

    // Modulo assignment
    var e: i64 = 17;
    e %= 5;
    println(e);

    // Chained compound assignments
    var x: i64 = 100;
    x += 10;
    x -= 5;
    x *= 2;
    x /= 3;
    x %= 7;
    println(x);

    // Float compound assignments
    var fx: f64 = 10.0;
    fx += 5.0;
    println(fx);

    fx -= 2.0;
    println(fx);

    fx *= 2.0;
    println(fx);

    fx /= 4.0;
    println(fx);

    // In a loop
    var sum: i64 = 0;
    var i: i64 = 1;
    while i <= 5 {
        sum += i;
        i += 1;
    }
    println(sum);
}
