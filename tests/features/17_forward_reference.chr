// Tests: forward references — functions that call functions declared later.
// The type checker's forward-declaration pre-pass must handle these.

// is_even calls is_odd, which is declared AFTER it.
fn is_even(n: i64) -> bool {
    if n == 0 {
        return true;
    }
    return is_odd(n - 1);
}

// is_odd calls is_even, which is declared BEFORE it.
fn is_odd(n: i64) -> bool {
    if n == 0 {
        return false;
    }
    return is_even(n - 1);
}

// Another pair of mutually recursive functions.
fn collatz_even(n: i64) -> i64 {
    return collatz_step(n / 2);
}

fn collatz_step(n: i64) -> i64 {
    if n == 1 {
        return 0;
    }
    if n % 2 == 0 {
        return 1 + collatz_even(n);
    } else {
        return 1 + collatz_odd(n);
    }
}

fn collatz_odd(n: i64) -> i64 {
    return collatz_step(3 * n + 1);
}

fn main() {
    // Mutual recursion: even/odd
    println(is_even(0));
    println(is_even(4));
    println(is_even(7));
    println(is_odd(1));
    println(is_odd(8));
    println(is_odd(3));

    // Collatz step count
    println(collatz_step(6));
    println(collatz_step(27));
}
