// Tests: manual assertion via if/else (require keyword not yet parsed).
// Demonstrates defensive programming patterns achievable without require.

fn safe_divide(a: i64, b: i64) -> i64 {
    if b == 0 {
        println("error: division by zero");
        return 0;
    }
    return a / b;
}

fn clamp(x: i64, lo: i64, hi: i64) -> i64 {
    if x < lo {
        return lo;
    }
    if x > hi {
        return hi;
    }
    return x;
}

fn non_negative(x: i64) -> i64 {
    if x < 0 {
        println("error: negative value");
        return 0;
    }
    return x;
}

fn main() {
    println(safe_divide(10, 2));
    println(safe_divide(10, 0));

    println(clamp(50, 0, 100));
    println(clamp(-10, 0, 100));
    println(clamp(200, 0, 100));

    println(non_negative(5));
    println(non_negative(-3));
}
