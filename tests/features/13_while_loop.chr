// Tests: while loops with various patterns

fn sum_to(n: i64) -> i64 {
    var total: i64 = 0;
    var i: i64 = 1;
    while i <= n {
        total = total + i;
        i = i + 1;
    }
    return total;
}

fn factorial(n: i64) -> i64 {
    var result: i64 = 1;
    var i: i64 = 2;
    while i <= n {
        result = result * i;
        i = i + 1;
    }
    return result;
}

fn count_digits(n: i64) -> i64 {
    if n == 0 {
        return 1;
    }
    var count: i64 = 0;
    var x: i64 = n;
    while x > 0 {
        x = x / 10;
        count = count + 1;
    }
    return count;
}

fn main() {
    // Basic counting loop
    var i: i64 = 0;
    while i < 5 {
        println(i);
        i = i + 1;
    }

    // Sum using a function
    let s10: i64 = sum_to(10);
    println(s10);

    // Factorial
    let f5: i64 = factorial(5);
    let f7: i64 = factorial(7);
    println(f5);
    println(f7);

    // Counting digits
    let d1: i64 = count_digits(0);
    let d2: i64 = count_digits(99);
    let d3: i64 = count_digits(1234567);
    println(d1);
    println(d2);
    println(d3);

    // Nested while loops
    var outer: i64 = 0;
    var pairs: i64 = 0;
    while outer < 3 {
        var inner: i64 = 0;
        while inner < 3 {
            pairs = pairs + 1;
            inner = inner + 1;
        }
        outer = outer + 1;
    }
    println(pairs);

    // While with compound assignment
    var x: i64 = 1;
    var product: i64 = 1;
    while x <= 5 {
        product *= x;
        x += 1;
    }
    println(product);
}
