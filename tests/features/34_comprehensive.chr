// Tests: comprehensive program combining all confirmed-working features:
// functions, recursion, mutual recursion, while loops, if/else chains,
// break/continue, compound assignments, all operator types, multiple types.

fn sign(n: i64) -> i64 {
    if n > 0 {
        return 1;
    } else {
        if n < 0 {
            return -1;
        } else {
            return 0;
        }
    }
}

fn abs(n: i64) -> i64 {
    if n < 0 {
        return -n;
    }
    return n;
}

fn max(a: i64, b: i64) -> i64 {
    if a > b {
        return a;
    }
    return b;
}

fn min(a: i64, b: i64) -> i64 {
    if a < b {
        return a;
    }
    return b;
}

fn clamp(x: i64, lo: i64, hi: i64) -> i64 {
    return max(lo, min(x, hi));
}

fn gcd(a: i64, b: i64) -> i64 {
    if b == 0 {
        return a;
    }
    return gcd(b, a % b);
}

fn lcm(a: i64, b: i64) -> i64 {
    return (a / gcd(a, b)) * b;
}

fn is_prime(n: i64) -> bool {
    if n < 2 {
        return false;
    }
    var i: i64 = 2;
    while i * i <= n {
        if n % i == 0 {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn count_primes(limit: i64) -> i64 {
    var count: i64 = 0;
    var n: i64 = 2;
    while n <= limit {
        if is_prime(n) {
            count += 1;
        }
        n += 1;
    }
    return count;
}

fn fib(n: i64) -> i64 {
    if n <= 1 {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

fn sum_digits(n: i64) -> i64 {
    var total: i64 = 0;
    var x: i64 = abs(n);
    while x > 0 {
        total += x % 10;
        x /= 10;
    }
    return total;
}

// Mutual recursion: even/odd
fn is_even(n: i64) -> bool {
    if n == 0 {
        return true;
    }
    return is_odd(n - 1);
}

fn is_odd(n: i64) -> bool {
    if n == 0 {
        return false;
    }
    return is_even(n - 1);
}

fn main() {
    // sign, abs, max, min, clamp
    println(sign(-7));
    println(sign(0));
    println(sign(3));
    println(abs(-42));
    println(max(3, 7));
    println(min(3, 7));
    println(clamp(-5, 0, 10));
    println(clamp(15, 0, 10));
    println(clamp(5, 0, 10));

    // gcd and lcm
    println(gcd(48, 18));
    println(lcm(4, 6));

    // prime counting
    let primes: i64 = count_primes(50);
    println(primes);

    // fibonacci
    var i: i64 = 0;
    while i <= 10 {
        println(fib(i));
        i += 1;
    }

    // digit sum
    println(sum_digits(12345));
    println(sum_digits(99));

    // mutual recursion
    println(is_even(10));
    println(is_odd(7));

    // Compound assignments
    var x: i64 = 100;
    x += 50;
    x -= 25;
    x *= 2;
    x /= 5;
    x %= 7;
    println(x);

    // Break and continue
    var evens: i64 = 0;
    var j: i64 = 0;
    while j < 30 {
        j += 1;
        if j % 2 != 0 {
            continue;
        }
        evens += 1;
        if evens == 5 {
            break;
        }
    }
    println(evens);
    println(j);

    // Float operations
    let pi: f64 = 3.14159265;
    let r: f64 = 3.0;
    let area: f64 = pi * r * r;
    println(area);

    // Boolean logic
    let a: bool = true;
    let b: bool = false;
    println(a && b);
    println(a || b);
    println(!a);
}
